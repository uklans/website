<header class="bg-slate-950 border-b border-slate-800 sticky top-0 z-50" x-data>
  <nav class="container" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16">

      {# Logo / Wordmark #}
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-8 h-8 bg-brand-500 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-brand-400 transition-colors">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />
          </svg>
        </div>
        <span class="font-bold text-slate-100 text-lg tracking-tight">
          UK LAN <span class="text-brand-400">Techs</span>
        </span>
      </a>

      {# Desktop navigation #}
      <div class="hidden md:flex items-center gap-1">
        {% for item in navigation %}
          <a
            href="{{ item.route }}"
            class="px-4 py-2 rounded-md text-sm font-medium transition-colors
              {{ page.url == item.route
                ? 'text-brand-400 bg-brand-500/10'
                : 'text-slate-400 hover:text-slate-100 hover:bg-slate-800'
              }}"
          >
            {{ item.name }}
          </a>
        {% endfor %}
      </div>

      {# Mobile menu button #}
      <button
        class="md:hidden p-2 rounded-md text-slate-400 hover:text-slate-100 hover:bg-slate-800 transition-colors"
        @click="$store.nav.toggle()"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path x-show="!$store.nav.isOpen" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          <path x-show="$store.nav.isOpen" x-cloak stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    {# Mobile navigation #}
    <div x-show="$store.nav.isOpen" x-cloak class="md:hidden border-t border-slate-800 py-3">
      {% for item in navigation %}
        <a
          href="{{ item.route }}"
          class="block px-3 py-2 rounded-md text-sm font-medium transition-colors mb-1
            {{ page.url == item.route
              ? 'text-brand-400 bg-brand-500/10'
              : 'text-slate-400 hover:text-slate-100 hover:bg-slate-800'
            }}"
          @click="$store.nav.close()"
        >
          {{ item.name }}
        </a>
      {% endfor %}
    </div>
  </nav>
</header>
